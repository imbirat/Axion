{
  "name": "axion",
  "version": "1.0.0",
  "description": "All-in-one Discord bot providing premium features for free",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "deploy:commands": "node dist/scripts/deploy-commands.js",
    "migrate": "node dist/scripts/migrate.js",
    "seed": "node dist/scripts/seed.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "pm2": "pm2 start ecosystem.config.js",
    "docker:start": "docker-compose up -d"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "discord.js": "^14.18.0",
    "kazagumo": "3.2.0",
    "shoukaku": "4.1.0",
    "mongoose": "^8.9.0",
    "ioredis": "^5.4.1",
    "zod": "^3.24.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "@google/generative-ai": "^0.21.0",
    "canvas": "^3.0.0",
    "axios": "^1.7.9",
    "ms": "^2.1.3",
    "node-cron": "^3.0.3",
    "pretty-ms": "^9.2.0",
    "humanize-duration": "^3.32.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ms": "^0.7.34",
    "@types/node-cron": "^3.0.11",
    "@types/humanize-duration": "^3.27.4",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
