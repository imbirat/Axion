# ===== CORE =====
# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Discord application client ID
CLIENT_ID=

# Bot owner's Discord user ID
OWNER_ID=1229349314736951321

# MongoDB connection string
MONGODB_URI=

# Redis connection URL
REDIS_URL=

# ===== MUSIC (Lavalink) =====
# Host address of your self-hosted Lavalink server
LAVALINK_HOST=

# WS port of your Lavalink server (default: 2333)
LAVALINK_PORT=2333

# Password configured in your Lavalink application.yml
LAVALINK_PASSWORD=

# Whether Lavalink connection uses WSS (true for SSL, false for non-SSL)
LAVALINK_SECURE=false

# Spotify API credentials for LavaSrc source resolution
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== AI =====
# Google Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
